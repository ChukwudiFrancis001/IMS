<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - IMS</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<%- include('../partials/sidebar') %>
<main class="main">
  <%- include('../partials/topbar') %>
  <section class="content">
    <div class="stat-grid">
      <div class="stat-card danger">
        <div class="val"><%= lowCount %></div>
        <div class="lbl">Critical Low Stock</div>
      </div>
      <div class="stat-card warning">
        <div class="val"><%= warningCount %></div>
        <div class="lbl">Warning Level</div>
      </div>
      <div class="stat-card">
        <div class="val"><%= products.length %></div>
        <div class="lbl">Active Products</div>
      </div>
      <div class="stat-card success">
        <div class="val"><%= recentTxns.length %></div>
        <div class="lbl">Recent Transactions</div>
      </div>
    </div>

    <% if (activeAlerts.length > 0) { %>
      <div class="alert alert-danger">
        <strong><%= activeAlerts.length %> active low-stock alert(s)</strong>
        <a href="/alerts">View alerts</a>
      </div>
    <% } %>

    <div class="page-actions">
      <a href="/transactions/new" class="btn btn-primary">Record Transaction</a>
      <% if (currentUser && currentUser.role === 'admin') { %>
        <a href="/products/new" class="btn btn-accent">Add Product</a>
        <a href="/reports/analytics" class="btn btn-outline">Analytics</a>
      <% } %>
    </div>

    <div class="dashboard-grid">
      <div class="card">
        <div class="card-header">
          <h2>Stock Status</h2>
          <a href="/reports/stock" class="btn btn-sm btn-outline">Full Report</a>
        </div>
        <div class="card-body">
          <table>
            <thead>
              <tr><th>Product</th><th>Current Stock</th><th>Threshold</th><th>Status</th></tr>
            </thead>
            <tbody>
              <% products.slice(0, 10).forEach(p => { %>
                <tr>
                  <td><strong><%= p.product_name %></strong><br><span class="text-muted"><%= p.sku %></span></td>
                  <td><strong><%= p.current_stock %></strong> <span class="text-muted"><%= p.unit_of_measure %></span></td>
                  <td><%= p.minimum_threshold %></td>
                  <td><span class="badge badge-<%= p.stock_status.toLowerCase() %>"><%= p.stock_status %></span></td>
                </tr>
              <% }) %>
              <% if (!products.length) { %>
                <tr><td colspan="4" class="empty-state">No products yet.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2>Recent Transactions</h2>
          <a href="/transactions" class="btn btn-sm btn-outline">View All</a>
        </div>
        <div class="card-body">
          <table>
            <thead>
              <tr><th>Product</th><th>Type</th><th>Qty</th><th>By</th></tr>
            </thead>
            <tbody>
              <% recentTxns.forEach(t => { %>
                <tr>
                  <td><%= t.product_name %></td>
                  <td><span class="badge <%= t.transaction_type === 'stock_in' ? 'badge-ok' : 'badge-low' %>"><%= t.transaction_type.replace('_', ' ') %></span></td>
                  <td><%= t.quantity %></td>
                  <td class="text-muted"><%= t.recorded_by %></td>
                </tr>
              <% }) %>
              <% if (!recentTxns.length) { %>
                <tr><td colspan="4" class="empty-state">No transactions yet.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>
</main>
</body>
</html>
