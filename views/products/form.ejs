<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><title><%= title %> — Haven</title><link rel="stylesheet" href="/css/style.css"></head>
<body>
<%- include('../partials/sidebar') %>
<div class="main"><%- include('../partials/topbar') %><div class="content">
  <% if (error && error.length) { %><div class="alert alert-danger"><%= error %></div><% } %>
  <div class="form-card">
    <h2 style="margin-bottom:20px;color:var(--primary)"><%= product ? 'Edit Product' : 'Add New Product' %></h2>
    <form method="POST" action="<%= product ? '/products/'+product.product_id : '/products' %>">
      <div class="form-row">
        <div class="form-group"><label>SKU *</label><input type="text" name="sku" value="<%= product ? product.sku : '' %>" required placeholder="e.g. PRD-001"></div>
        <div class="form-group"><label>Product Name *</label><input type="text" name="product_name" value="<%= product ? product.product_name : '' %>" required></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Category *</label>
          <select name="category_id" required>
            <option value="">— Select Category —</option>
            <% categories.forEach(c => { %><option value="<%= c.category_id %>" <%= product && product.category_id==c.category_id?'selected':'' %>><%= c.category_name %></option><% }) %>
          </select>
        </div>
        <div class="form-group"><label>Unit of Measure</label><input type="text" name="unit_of_measure" value="<%= product ? product.unit_of_measure : 'units' %>"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Minimum Threshold</label><input type="number" name="minimum_threshold" min="0" value="<%= product ? product.minimum_threshold : 0 %>"></div>
        <div class="form-group"><label>Unit Cost</label><input type="number" name="unit_cost" step="0.01" min="0" value="<%= product ? product.unit_cost : 0 %>"></div>
      </div>
      <% if (!product) { %>
      <div class="form-group"><label>Initial Stock Quantity</label><input type="number" name="current_stock" min="0" value="0" placeholder="Enter starting stock (optional)"></div>
      <% } %>
      <div class="form-group"><label>Description (optional)</label><textarea name="description" rows="3"><%= product ? product.description||'' : '' %></textarea></div>
      <div style="display:flex;gap:10px;margin-top:8px">
        <button type="submit" class="btn btn-primary"><%= product ? 'Save Changes' : 'Create Product' %></button>
        <a href="/products" class="btn btn-outline">Cancel</a>
      </div>
    </form>
  </div>
</div></div>
</body></html>
