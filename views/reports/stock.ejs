<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><title>Stock Report — IMS</title><link rel="stylesheet" href="/css/style.css"></head>
<body>
<%- include('../partials/sidebar') %>
<div class="main"><%- include('../partials/topbar') %><div class="content">
  <div class="card">
    <div class="card-header"><h2>Real-Time Stock Report — <%= new Date().toLocaleDateString() %></h2></div>
    <div class="card-body"><table>
      <thead><tr><th>SKU</th><th>Product Name</th><th>Category</th><th>Current Stock</th><th>Min. Threshold</th><th>Unit</th><th>Status</th></tr></thead>
      <tbody>
        <% products.forEach(p => { %>
        <tr>
          <td class="text-muted"><%= p.sku %></td>
          <td><strong><%= p.product_name %></strong></td>
          <td><%= p.category_name %></td>
          <td style="font-weight:700;font-size:1.05rem"><%= p.current_stock %></td>
          <td><%= p.minimum_threshold %></td>
          <td class="text-muted"><%= p.unit_of_measure %></td>
          <td><span class="badge badge-<%= p.stock_status.toLowerCase() %>"><%= p.stock_status %></span></td>
        </tr>
        <% }) %>
      </tbody>
    </table></div>
  </div>
</div></div>
</body></html>