<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><title>Register — Haven</title><script src="/js/theme.js"></script><link rel="stylesheet" href="/css/style.css"></head>
<body style="margin:0">
<div class="login-wrap"><div class="login-card">
  <h1>Haven</h1><p>Create a staff account.</p>
  <% if (error && error.length) { %><div class="alert alert-danger"><%= error %></div><% } %>
  <% if (success && success.length) { %><div class="alert alert-success"><%= success %></div><% } %>
  <form method="POST" action="/auth/register">
    <div class="form-group"><label>Full Name</label><input type="text" name="full_name" placeholder="Enter full name" required autofocus></div>
    <div class="form-group"><label>Email</label><input type="email" name="email" placeholder="Enter email" required></div>
    <div class="form-group"><label>Password</label><input type="password" name="password" placeholder="Enter password (min 6 characters)" required minlength="6"></div>
    <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:11px">Create Account</button>
  </form>
  <p style="text-align:center;margin-top:16px;font-size:.85rem"><a href="/auth/login">Already have an account? Sign in</a></p>
</div></div>
</body></html>
