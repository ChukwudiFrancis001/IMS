<!DOCTYPE html><html lang="en"><head><meta charset="UTF-8"><title>Forgot Password — Haven</title><script src="/js/theme.js"></script><link rel="stylesheet" href="/css/style.css"></head>
<body style="margin:0">
<div class="login-wrap"><div class="login-card">
  <div id="forgot-form">
    <h1>Forgot Password</h1><p>Enter your email to receive a reset link.</p>
    <div id="error-msg" class="alert alert-danger" style="display:none"></div>
    <form id="emailForm">
      <div class="form-group"><label>Email</label><input type="email" name="email" id="emailInput" placeholder="Enter your email" required autofocus></div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:11px" id="submitBtn">Send Reset Link</button>
    </form>
    <p style="text-align:center;margin-top:16px;font-size:.85rem"><a href="/auth/login">Back to Sign In</a></p>
  </div>
  <div id="check-email" style="display:none;text-align:center">
    <h1>Check Your Email</h1><p>We've sent a password reset link to your email address. Click the link in the email to reset your password.</p>
    <a href="/auth/login" class="btn btn-primary" style="margin-top:16px">Back to Sign In</a>
  </div>
</div></div>
<script>
  document.getElementById('emailForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('emailInput').value;
    const errEl = document.getElementById('error-msg');
    const submitBtn = document.getElementById('submitBtn');
    errEl.style.display = 'none';
    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    try {
      const res = await fetch('/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({ email })
      });
      const data = await res.json();
      if (data.error) {
        errEl.textContent = data.error;
        errEl.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Reset Link';
      } else {
        document.getElementById('forgot-form').style.display = 'none';
        document.getElementById('check-email').style.display = 'block';
      }
    } catch (err) {
      errEl.textContent = 'Something went wrong. Please try again.';
      errEl.style.display = 'block';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Reset Link';
    }
  });
</script>
</body></html>